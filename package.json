{
  "name": "wadang",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "prebuild": "hardhat compile",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "hardhat compile && tsc --noEmit",
    "test": "vitest run",
    "test:contracts": "hardhat test",
    "test:e2e": "playwright test",
    "build:cloudflare": "opennextjs-cloudflare build",
    "preview:cloudflare": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:cloudflare": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "check:attesters": "node scripts/check-attesters.mjs",
    "check:deployer": "hardhat run scripts/check-deployer.ts --network giwaSepolia",
    "e2e:testnet": "hardhat run scripts/testnet-e2e.ts --network giwaSepolia",
    "export:pdfs": "node scripts/export-pdfs.mjs",
    "capture:qa": "node scripts/capture-qa.mjs",
    "check:client-boundaries": "node scripts/check-client-boundaries.mjs",
    "check:release": "node scripts/check-release.mjs",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm test:contracts && pnpm build && pnpm check:client-boundaries && pnpm build:cloudflare"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@tanstack/react-query": "^5.101.2",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "viem": "2.55.2",
    "wagmi": "3.7.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ignition": "^3.1.8",
    "@nomicfoundation/hardhat-keystore": "3.0.12",
    "@nomicfoundation/hardhat-toolbox-viem": "5.0.7",
    "@nomicfoundation/hardhat-verify": "^3.0.21",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "hardhat": "3.9.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "4.1.10",
    "wrangler": "^4.110.0"
  }
}
